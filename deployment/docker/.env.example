# example environment variables
# read more about all env vars at https://aksa.local/docs/self-hosting/env-vars/

## Aksa backend
AKSA_BACKEND_VERSION=4.5.0
AKSA_LOG_LEVEL="INFO"
AKSA_SERVER_PORT=8080
AKSA_BASE_PATH="/api"
## Uses the hardcoded insecure key for development
AKSA_INSECURE=
## JWT Private Key (ECDSA). Generate a new key for PRODUCTION
AKSA_PRIVATE_KEY=
## NATS URL
AKSA_SERVER_NATS_URL="nats://nats:4222"
## Redis if you use it instead of NATS
REDIS_HOST=
REDIS_USERNAME=
REDIS_PASSWORD=
## Webhook URL for feedback
WEBHOOK_URL=
## OTel
AKSA_OTEL_GRPC=
AKSA_OTEL_HTTP=
## Auth Providers
AUTH_CALLBACK_HOST=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=http://oidc.localhost:5556/dex/.well-known/openid-configuration
# Session Secret
SESSION_SECRET=
AKSA_ENABLE_EXPERIMENTAL_AUTH_FILE_SYSTEM_STORE=

## Aksa frontend
AKSA_FRONTEND_VERSION=4.5.0
AKSA_LISTEN_PORT=8080
AKSA_SERVER_URL="/api"
## Websocket URL (wss:// or ws://)
# AKSA_WEBSOCKET_URL="ws://localhost:8080/api"
## Show Legal Documents (Cookie Policy, Privacy Policy, Terms of Service)
AKSA_SHOW_LEGAL_DOCUMENTS=false
## Analytics (Plausible)
ANALYTICS_DATA_DOMAIN=
ANALYTICS_SRC=
AKSA_CLARITY_ID=

## Postgres
POSTGRES_VERSION=18.1
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

## Nats
NATS_VERSION=2.12.3

## Caddy
CADDY_VERSION=2.10.2

